{
  "name": "Loz",
  "scopeName": "source.loz",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#function-like-declarations"
    },
    {
      "include": "#type-declarations"
    },
    {
      "include": "#named-declarations"
    },
    {
      "include": "#module-declarations"
    },
    {
      "include": "#built-in-namespaces"
    },
    {
      "include": "#method-calls"
    },
    {
      "include": "#function-calls"
    },
    {
      "include": "#types"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#language-constants"
    },
    {
      "include": "#self"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.loz",
          "begin": "//",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.comment.loz"
            }
          },
          "end": "$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.loz",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.loz"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.loz"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.loz",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.loz",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "function-like-declarations": {
      "patterns": [
        {
          "match": "\\b(async)\\s+(task)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "storage.modifier.async.loz"
            },
            "2": {
              "name": "keyword.declaration.task.loz"
            },
            "3": {
              "name": "entity.name.function.loz"
            }
          }
        },
        {
          "match": "\\b(func|tool|task)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.loz"
            },
            "2": {
              "name": "entity.name.function.loz"
            }
          }
        }
      ]
    },
    "type-declarations": {
      "patterns": [
        {
          "match": "\\b(struct|schema|impl)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.loz"
            },
            "2": {
              "name": "entity.name.type.loz"
            }
          }
        }
      ]
    },
    "named-declarations": {
      "patterns": [
        {
          "match": "\\b(agent|workflow)\\s+([A-Za-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.loz"
            },
            "2": {
              "name": "entity.name.type.loz"
            }
          }
        }
      ]
    },
    "module-declarations": {
      "patterns": [
        {
          "match": "\\b(module|import)\\s+([A-Za-z_][A-Za-z0-9_\\.:]*)",
          "captures": {
            "1": {
              "name": "keyword.control.import.loz"
            },
            "2": {
              "name": "entity.name.namespace.loz"
            }
          }
        }
      ]
    },
    "built-in-namespaces": {
      "patterns": [
        {
          "name": "support.type.namespace.loz",
          "match": "\\b(?:io|json|schema|python|llm)\\b(?=\\s*\\.)"
        }
      ]
    },
    "method-calls": {
      "patterns": [
        {
          "match": "(\\.)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "punctuation.accessor.dot.loz"
            },
            "2": {
              "name": "support.function.method.loz"
            }
          }
        }
      ]
    },
    "function-calls": {
      "patterns": [
        {
          "name": "entity.name.function.loz",
          "match": "\\b(?!(?:if|else|while|for|return|await|func|tool|task|agent|workflow|schema|struct|impl|module|import|async|step|break|continue|mut|const)\\b)(?:[A-Za-z_][A-Za-z0-9_]*)\\b(?=\\s*\\()"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.loz",
          "match": "\\b(?:i8|i16|i32|i64|u8|u16|u32|u64|Int|Text|Bool|Json|f32|f64|void|Void)\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.loz",
          "match": "\\b(?:module|import|const|mut|func|return|if|else|while|for|in|break|continue|struct|impl|schema|tool|agent|task|workflow|step|async|await)\\b"
        }
      ]
    },
    "language-constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.loz",
          "match": "\\b(?:true|false)\\b"
        }
      ]
    },
    "self": {
      "patterns": [
        {
          "name": "variable.language.self.loz",
          "match": "\\bself\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.loz",
          "match": "->|==|!=|>=|<=|&&|\\|\\||=|>|<|\\+|-|\\*|/|%|!"
        }
      ]
    }
  }
}
